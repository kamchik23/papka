{
  "version": 2,
  "builds": [
    {
      "src": "demo/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "headers": [
    {
      "source": "/static/unity/Build/(.*).gz",
      "headers": [
        { "key": "Content-Encoding", "value": "gzip" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/static/unity/Build/(.*).wasm.gz",
      "headers": [
        { "key": "Content-Encoding", "value": "gzip" },
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "demo/wsgi.py"
    }
  ]
}