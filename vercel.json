{
  "version": 2,
  "builds": [
    {
      "src": "demo/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "cafe/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "demo/wsgi.py"
    }
  ],
  "installCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py collectstatic --noinput"
}